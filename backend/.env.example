# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=haulsync
POSTGRES_PASSWORD=haulsync
POSTGRES_DB=haulsync_ct
DATABASE_URL=postgresql://haulsync:haulsync@localhost:5432/haulsync_ct

# ── Auth ───────────────────────────────────────────────────────────────────────
# Use the same JWT_SECRET as HaulSync core for shared sessions
JWT_SECRET=change-me-in-production-use-a-long-random-string

# ── Disruption engine thresholds (all overridable per-rule in Rules module) ───
HALT_THRESHOLD_MINUTES=30
DELAY_THRESHOLD_MINUTES=60
SLA_BREACH_WARNING_MINUTES=120
ROUTE_DEVIATION_KM=5
NIGHT_DRIVING_START_HOUR=22
NIGHT_DRIVING_END_HOUR=5

# ── Notifications ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASS=your-smtp-password
WEBHOOK_URL=

# ── Source integrations ────────────────────────────────────────────────────────
# Add one block per connected source. Control Tower skips adapters
# whose env vars are absent — only configure what you are running.
#
# HAULSYNC_FTL_URL=http://haulsync-ftl:5001
# HAULSYNC_FTL_API_KEY=your-api-key
#
# HAULSYNC_TMS_URL=http://your-tms.internal
# HAULSYNC_TMS_API_KEY=your-api-key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5002
NODE_ENV=development
FRONTEND_URL=http://localhost:3002
